@{
    ViewData["Title"] = "Acceso Seguro";
}

<div class="flex items-center justify-center py-10 px-4 sm:px-6 lg:px-8 min-h-[calc(100vh-16rem)]">

    <div class="max-w-lg w-full bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-slate-200 relative overflow-hidden">

        <!-- Elemento decorativo de fondo -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-50 rounded-full blur-3xl opacity-60 pointer-events-none"></div>

        <!-- Cabecera del Formulario -->
        <div class="text-center mb-10 relative z-10">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-blue-50 text-blue-700 mb-5 shadow-inner border border-blue-100">
                <i class="fas fa-shield-alt text-3xl"></i>
            </div>
            <h1 id="titulo-form" class="text-3xl font-black text-slate-900 mb-2 tracking-tight">Bienvenido de vuelta</h1>
            <p id="subtitulo-form" class="text-slate-500 font-medium text-sm">Ingresa tus credenciales para acceder a tu cuenta y gestionar tu infraestructura.</p>
        </div>

        <div class="space-y-6 relative z-10">

            <!-- Campo: Nombre Completo (Oculto por defecto) -->
            <div id="campo-nombre" class="hidden">
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Nombre Completo *</label>
                <div class="relative">
                    <i class="fas fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" id="nombre" placeholder="Ej. Juan Pérez"
                           class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800" />
                </div>
            </div>

            <!-- Campo: Correo -->
            <div>
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Correo Electrónico *</label>
                <div class="relative">
                    <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="email" id="email" placeholder="tu@correo.com"
                           class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800" />
                </div>
            </div>

            <!-- Campo: Contraseña -->
            <div>
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Contraseña *</label>
                <div class="relative">
                    <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="password" id="password" placeholder="••••••••"
                           class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800" />
                </div>
            </div>

            <!-- Mensaje de Error Estilizado -->
            <div id="mensaje-error" class="hidden bg-rose-50 border-l-4 border-rose-500 text-rose-700 p-4 rounded-r-xl text-sm font-bold shadow-sm flex items-start gap-3">
                <i class="fas fa-exclamation-circle text-lg mt-0.5"></i>
                <span id="texto-error-interno">Error genérico.</span>
            </div>

            <!-- Botón de Acción -->
            <button id="btn-accion" onclick="procesarAuth()"
                    class="w-full bg-blue-800 hover:bg-blue-700 text-white font-black py-4 px-4 rounded-xl shadow-lg hover:shadow-blue-800/30 transition-all mt-4 flex items-center justify-center gap-2 group text-lg">
                <i class="fas fa-sign-in-alt group-hover:translate-x-1 transition-transform"></i>
                <span id="texto-btn-accion">Iniciar Sesión</span>
            </button>
        </div>

        <!-- Footer / Toggle -->
        <div class="mt-8 text-center border-t border-slate-100 pt-8 relative z-10">
            <p class="text-sm text-slate-600 font-medium">
                <span id="texto-toggle">¿No tienes una cuenta?</span>
                <button onclick="toggleModo()" class="font-black text-blue-800 hover:text-blue-600 ml-1 transition-colors hover:underline">
                    <span id="btn-toggle">Regístrate aquí</span>
                </button>
            </p>

            <div class="mt-6 flex items-center justify-center gap-2 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                <i class="fas fa-lock"></i> Autenticación cifrada por Supabase
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        let modoRegistro = false;

        // 1. Alternar la interfaz entre Login y Registro
        function toggleModo() {
            modoRegistro = !modoRegistro;

            const campoNombre = document.getElementById('campo-nombre');
            const titulo = document.getElementById('titulo-form');
            const subtitulo = document.getElementById('subtitulo-form');
            const textoBtnAccion = document.getElementById('texto-btn-accion'); // Modificado para respetar el ícono
            const textoToggle = document.getElementById('texto-toggle');
            const btnToggle = document.getElementById('btn-toggle');
            const divError = document.getElementById('mensaje-error');

            divError.classList.add('hidden'); // Limpiamos errores al cambiar

            if (modoRegistro) {
                campoNombre.classList.remove('hidden');
                titulo.innerText = 'Crea tu cuenta';
                subtitulo.innerText = 'Regístrate para gestionar tus compras, hardware y tickets SOC.';
                textoBtnAccion.innerText = 'Crear mi cuenta';
                textoToggle.innerText = '¿Ya tienes una cuenta?';
                btnToggle.innerText = 'Inicia sesión';
            } else {
                campoNombre.classList.add('hidden');
                titulo.innerText = 'Bienvenido de vuelta';
                subtitulo.innerText = 'Ingresa tus credenciales para acceder a tu cuenta y gestionar tu infraestructura.';
                textoBtnAccion.innerText = 'Iniciar Sesión';
                textoToggle.innerText = '¿No tienes una cuenta?';
                btnToggle.innerText = 'Regístrate aquí';
            }
        }

        // 2. Comunicarse con el servicio de Identidad (usando supabaseClient)
        async function procesarAuth() {
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const divError = document.getElementById('mensaje-error');
            const btnAccion = document.getElementById('btn-accion');
            const textoBtnAccion = document.getElementById('texto-btn-accion');

            if (!email || !password) {
                mostrarError("Por favor completa todos los campos requeridos.");
                return;
            }

            btnAccion.disabled = true;
            textoBtnAccion.innerText = 'Procesando...';
            btnAccion.classList.add('opacity-75', 'cursor-not-allowed');
            divError.classList.add('hidden');

            try {
                if (modoRegistro) {
                    const nombre = document.getElementById('nombre').value.trim();
                    if (!nombre) {
                        mostrarError("El nombre es obligatorio para el registro.");
                        throw new Error("Validation failed");
                    }

                    // USAMOS supabaseClient EN LUGAR DE supabase
                    const { data, error } = await supabaseClient.auth.signUp({
                        email: email,
                        password: password,
                        options: { data: { full_name: nombre } }
                    });

                    if (error) throw error;

                    if (data.user) {
                        await fetch('/Account/SincronizarPerfil', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                Id: data.user.id,
                                NombreCompleto: nombre,
                                Email: email
                            })
                        });
                    }

                    alert("¡Registro exitoso! Ya puedes iniciar sesión en la plataforma.");
                    toggleModo();

                } else {
                    // LOGIN CON supabaseClient
                    const { data, error } = await supabaseClient.auth.signInWithPassword({
                        email: email,
                        password: password,
                    });

                    if (error) throw error;

                    // AVISAMOS A C# PARA QUE CREE LA COOKIE
                    if (data.user) {
                        await fetch('/Account/CrearSesionCookie', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                Id: data.user.id,
                                Email: email,
                                NombreCompleto: "" // No lo necesitamos aquí, C# lo saca de BD
                            })
                        });
                    }

                    window.location.href = '/Tienda/Index';
                }

            } catch (err) {
                if (err.message !== "Validation failed") {
                    mostrarError(err.message);
                }
            } finally {
                // Siempre reactivamos el botón al terminar, pase lo que pase
                btnAccion.disabled = false;
                textoBtnAccion.innerText = modoRegistro ? 'Crear mi cuenta' : 'Iniciar Sesión';
                btnAccion.classList.remove('opacity-75', 'cursor-not-allowed');
            }
        }

        // 3. Función auxiliar para mostrar errores de forma amigable
        function mostrarError(mensaje) {
            const divError = document.getElementById('mensaje-error');
            const textoError = document.getElementById('texto-error-interno');

            if (mensaje.includes("Invalid login credentials")) {
                mensaje = "Correo o contraseña incorrectos. Verifica tus credenciales.";
            } else if (mensaje.includes("User already registered")) {
                mensaje = "Ya existe una cuenta activa con este correo electrónico.";
            } else if (mensaje.includes("Password should be at least")) {
                mensaje = "Por seguridad, la contraseña debe tener al menos 6 caracteres.";
            }

            textoError.innerText = mensaje;
            divError.classList.remove('hidden');
        }
    </script>
}