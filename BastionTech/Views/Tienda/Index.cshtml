@model IEnumerable<BastionTech.Models.Producto>

@{
    ViewData["Title"] = "Catálogo";
}

<div class="bg-blue-800 text-white py-12 px-8 rounded-2xl mb-10 shadow-lg">
    <h1 class="text-4xl font-extrabold mb-3">Soluciones IT & Hardware</h1>
    <p class="text-lg text-blue-200 max-w-2xl">Equipos de alto rendimiento y servicios profesionales para tu infraestructura.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    @foreach (var item in Model)
    {
        <div class="bg-white shadow-sm rounded-xl border border-slate-200 overflow-hidden flex flex-col transition-transform hover:-translate-y-1 hover:shadow-md">
            <div class="relative h-48 w-full bg-slate-100 p-4 flex items-center justify-center">
                @if (!string.IsNullOrEmpty(item.UrlImagen))
                {
                    <img src="@item.UrlImagen" alt="@item.Nombre" class="max-h-full object-contain mix-blend-multiply" />
                }
                <div class="absolute top-3 right-3">
                    <span class="bg-slate-800 text-white text-xs font-bold px-3 py-1 rounded-full">
                        @(item.EsServicio ? "Servicio IT" : "Hardware")
                    </span>
                </div>
            </div>

            <div class="p-5 flex-1 flex flex-col">
                <h2 class="text-lg font-bold text-slate-900 leading-tight mb-2">@item.Nombre</h2>
                <p class="text-slate-500 text-sm mb-5 flex-1 line-clamp-2">@item.DescripcionCorta</p>

                <div class="flex justify-between items-end mt-auto pt-4 border-t border-slate-100">
                    <div>
                        <span class="block text-xs text-slate-400 font-medium mb-1">Precio</span>
                        <span class="text-2xl font-black text-blue-800">$@item.Precio.ToString("N0")</span>
                    </div>

                    <a asp-action="Detalle" asp-route-id="@item.Id" class="bg-slate-100 hover:bg-blue-800 hover:text-white text-blue-900 font-semibold rounded-lg px-4 py-2 transition-colors">
                        Ver más
                    </a>
                </div>
            </div>
        </div>
    }
</div>