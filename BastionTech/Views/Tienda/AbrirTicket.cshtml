@model BastionTech.Models.TicketServicio
@{
    ViewData["Title"] = "Solicitar Soporte Técnico";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Migas de pan (Breadcrumbs) -->
    <nav class="flex text-sm text-slate-500 mb-6 font-medium" aria-label="Breadcrumb">
        <a asp-controller="Tienda" asp-action="Index" class="hover:text-blue-800 transition-colors flex items-center">
            <i class="fas fa-home mr-2"></i> Inicio
        </a>
        <span class="mx-3 text-slate-300">/</span>
        <span class="text-slate-800 font-bold">Mesa de Ayuda</span>
    </nav>

    <!-- Cabecera de la Sección -->
    <div class="mb-10 border-b border-slate-200 pb-6 flex items-center gap-4">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-100 text-blue-800 flex-shrink-0">
            <i class="fas fa-headset text-2xl"></i>
        </div>
        <div>
            <h1 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">Centro de Soporte IT</h1>
            <p class="text-sm md:text-base text-slate-500 mt-1 font-medium">Describe el problema de tu equipo y nuestros técnicos especializados se encargarán del resto.</p>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <!-- Alerta de Validación Estilizada -->
        <div class="bg-rose-50 border-l-4 border-rose-500 text-rose-700 p-5 mb-8 rounded-r-2xl shadow-sm flex gap-3 items-start">
            <i class="fas fa-exclamation-circle text-xl mt-0.5"></i>
            <div asp-validation-summary="All" class="font-medium text-sm"></div>
        </div>
    }

    <!-- Contenedor del Formulario (Diseño Retail/Corporate) -->
    <form asp-action="AbrirTicket" method="post" class="bg-white p-8 md:p-12 rounded-3xl shadow-lg border border-slate-200">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <!-- Asunto -->
            <div class="md:col-span-2">
                <label asp-for="Asunto" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Asunto del Problema *</label>
                <div class="relative">
                    <i class="fas fa-laptop-medical absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input asp-for="Asunto" required class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800" placeholder="Ej. Pantalla azul en Laptop, Formateo de PC, etc." />
                </div>
            </div>

            <!-- Teléfono -->
            <div class="md:col-span-2">
                <label asp-for="Telefono" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Número de Contacto (Celular / WhatsApp) *</label>
                <div class="relative">
                    <i class="fas fa-phone absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input asp-for="Telefono" type="tel" required class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700" placeholder="Ej. +591 70000000" />
                </div>
            </div>

            <!-- Notas Técnicas -->
            <div class="md:col-span-2">
                <label asp-for="NotasTecnicas" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Descripción Detallada / Síntomas *</label>
                <div class="relative">
                    <i class="fas fa-clipboard-list absolute left-4 top-4 text-slate-400"></i>
                    <textarea asp-for="NotasTecnicas" required rows="5" class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700 resize-y" placeholder="Por favor, detalla los síntomas que presenta tu equipo, cuándo comenzó el problema y cualquier mensaje de error que hayas visto..."></textarea>
                </div>
            </div>
        </div>

        @if (User.Identity == null || !User.Identity.IsAuthenticated)
        {
            <div class="bg-amber-50 rounded-2xl p-5 flex items-start border border-amber-200 mb-8">
                <i class="fas fa-info-circle text-amber-500 mt-0.5 mr-3 text-lg"></i>
                <p class="text-sm text-amber-800 font-medium leading-relaxed">
                    Estás abriendo este ticket como invitado. Si dejas tu equipo en nuestra tienda física, menciona el asunto que escribiste arriba para vincularlo a tu orden de trabajo.
                </p>
            </div>
        }

        <div class="pt-8 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-6">

            <!-- Trust Badges de Soporte -->
            <div class="flex gap-4 text-xs font-medium text-slate-500 w-full sm:w-auto">
                <div class="flex items-center gap-2">
                    <i class="fas fa-user-shield text-emerald-600"></i>
                    <span>Técnicos Certificados</span>
                </div>
                <div class="flex items-center gap-2">
                    <i class="fas fa-lock text-blue-600"></i>
                    <span>Privacidad de Datos</span>
                </div>
            </div>

            <button type="submit" class="w-full sm:w-auto px-10 py-4 bg-blue-800 hover:bg-blue-700 text-white rounded-xl font-black shadow-lg hover:shadow-blue-800/30 transition-all flex items-center justify-center gap-2 text-lg group">
                <i class="fas fa-paper-plane group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform"></i> Enviar Solicitud
            </button>
        </div>
    </form>
</div>