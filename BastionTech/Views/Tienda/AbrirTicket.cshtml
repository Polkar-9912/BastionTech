@model BastionTech.Models.TicketServicio
@{
    ViewData["Title"] = "Solicitar Soporte Técnico";
}

<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 text-blue-800 mb-4">
            <i class="fas fa-headset text-3xl"></i>
        </div>
        <h1 class="text-4xl font-black text-slate-800 tracking-tight">Centro de Soporte IT</h1>
        <p class="text-lg text-slate-500 mt-2">Describe el problema de tu equipo y nuestros técnicos se encargarán del resto.</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-rose-50 border-l-4 border-rose-500 text-rose-700 p-4 mb-6 rounded-r-lg shadow-sm">
            <div asp-validation-summary="All" class="font-medium text-sm"></div>
        </div>
    }

    <form asp-action="AbrirTicket" method="post" class="bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-slate-100">

        <div class="space-y-6">
            <div>
                <label asp-for="Asunto" class="block text-sm font-bold text-slate-700 mb-2">Asunto del Problema *</label>
                <input asp-for="Asunto" required class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" placeholder="Ej. Pantalla azul en Laptop, Formateo de PC, etc." />
            </div>

            <div>
                <label asp-for="Telefono" class="block text-sm font-bold text-slate-700 mb-2">Número de Contacto (Celular / WhatsApp) *</label>
                <input asp-for="Telefono" type="tel" required class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" placeholder="Ej. +591 70000000 o 4444444" />
            </div>

            <div>
                <label asp-for="NotasTecnicas" class="block text-sm font-bold text-slate-700 mb-2">Descripción Detallada / Síntomas *</label>
                <textarea asp-for="NotasTecnicas" required rows="6" class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" placeholder="Por favor, detalla los síntomas que presenta tu equipo, cuándo comenzó el problema y cualquier mensaje de error que hayas visto..."></textarea>
            </div>

            @if (User.Identity == null || !User.Identity.IsAuthenticated)
            {
                <div class="bg-amber-50 rounded-lg p-4 flex items-start border border-amber-200">
                    <i class="fas fa-info-circle text-amber-500 mt-0.5 mr-3"></i>
                    <p class="text-sm text-amber-800 font-medium">
                        Estás abriendo este ticket como invitado. Si dejas tu equipo en nuestra tienda física, menciona el asunto que escribiste arriba para vincularlo a tu orden de trabajo.
                    </p>
                </div>
            }
        </div>

        <div class="mt-8 pt-6 border-t border-slate-100 flex justify-end">
            <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-blue-800 hover:bg-blue-700 text-white rounded-lg font-bold shadow-md transition-all flex items-center justify-center">
                <i class="fas fa-paper-plane mr-2"></i> Enviar Solicitud
            </button>
        </div>
    </form>
</div>