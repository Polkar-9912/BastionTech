@model BastionTech.Models.Producto

@{
    ViewData["Title"] = Model.Nombre;
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="flex text-sm text-slate-500 mb-6 font-medium" aria-label="Breadcrumb">
        <a asp-controller="Tienda" asp-action="Index" class="hover:text-blue-800 transition-colors flex items-center">
            <i class="fas fa-home mr-2"></i> Inicio
        </a>
        <span class="mx-3 text-slate-300">/</span>
        <a asp-controller="Tienda" asp-action="Index" class="hover:text-blue-800 transition-colors">
            Catálogo
        </a>
        <span class="mx-3 text-slate-300">/</span>
        <span class="text-slate-800 font-bold truncate max-w-xs">@Model.Nombre</span>
    </nav>

    <div class="bg-white rounded-3xl shadow-lg border border-slate-200 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">

            <div class="flex justify-center items-center bg-slate-50 p-10 lg:p-16 relative border-b lg:border-b-0 lg:border-r border-slate-200">

                <div class="absolute top-6 left-6">
                    @if (Model.EsServicio)
                    {
                        <span class="bg-purple-100 text-purple-800 border border-purple-200 text-xs font-black px-3 py-1.5 rounded-lg tracking-wide uppercase shadow-sm flex items-center">
                            <i class="fas fa-network-wired mr-2"></i> Servicio IT
                        </span>
                    }
                    else
                    {
                        <span class="bg-blue-100 text-blue-800 border border-blue-200 text-xs font-black px-3 py-1.5 rounded-lg tracking-wide uppercase shadow-sm flex items-center">
                            <i class="fas fa-microchip mr-2"></i> Hardware
                        </span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.UrlImagen))
                {
                    <img src="@Model.UrlImagen" alt="@Model.Nombre" class="w-full max-w-md object-contain mix-blend-multiply drop-shadow-md hover:scale-105 transition-transform duration-500" />
                }
                else
                {
                    <div class="text-center text-slate-300">
                        <i class="fas fa-box-open text-7xl mb-4 block"></i>
                        <span class="text-sm font-bold">Sin imagen disponible</span>
                    </div>
                }
            </div>

            <div class="p-8 lg:p-12 flex flex-col justify-center bg-white">

                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 block">@Model.Categoria</span>
                <h1 class="text-3xl md:text-4xl font-black text-slate-900 mb-6 leading-tight tracking-tight">@Model.Nombre</h1>

                <div class="mb-6 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <div class="text-4xl md:text-5xl font-black text-blue-800 tracking-tight">
                        Bs. @Model.Precio.ToString("N2")
                    </div>
                    <div class="mt-2 text-sm text-slate-500 font-medium flex items-center">
                        <i class="fas fa-file-invoice mr-2 text-slate-400"></i> Precio incluye factura con NIT
                    </div>
                </div>

                <div class="prose prose-sm text-slate-600 mb-8 leading-relaxed">
                    <h3 class="text-slate-800 font-bold mb-2 uppercase text-xs tracking-wider">Especificaciones:</h3>
                    <p>@Model.EspecificacionesTecnicas</p>
                </div>

                <div class="mb-8 flex items-center gap-3 border-y border-slate-100 py-4">
                    @if (Model.Stock > 0 || Model.EsServicio)
                    {
                        <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 text-emerald-600">
                            <i class="fas fa-check"></i>
                        </div>
                        <div>
                            <span class="block text-sm font-bold text-slate-800">
                                @(Model.EsServicio ? "Servicio de Integración Activo" : "Disponibilidad Inmediata")
                            </span>
                            <span class="block text-xs text-slate-500">
                                @(Model.EsServicio ? "Coordina la ejecución tras la compra" : $"Tenemos {Model.Stock} unidad(es) en nuestro almacén")
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="w-10 h-10 rounded-full bg-rose-100 flex items-center justify-center flex-shrink-0 text-rose-600">
                            <i class="fas fa-times"></i>
                        </div>
                        <div>
                            <span class="block text-sm font-bold text-slate-800">Producto Agotado</span>
                            <span class="block text-xs text-slate-500">Contacta a soporte para reabastecimiento</span>
                        </div>
                    }
                </div>

                <div class="flex flex-col sm:flex-row gap-4 mb-8">
                    <div class="relative w-full sm:w-32 flex-shrink-0">
                        <label for="cantidad-item" class="absolute -top-2.5 left-3 bg-white px-1 text-[10px] font-bold text-slate-400 uppercase tracking-wider">Cantidad</label>
                        <input type="number" id="cantidad-item" value="1" min="1" max="@(Model.EsServicio ? 1 : Model.Stock)"
                               class="w-full border-2 border-slate-200 rounded-xl py-3.5 px-4 text-center font-black text-slate-700 text-lg focus:outline-none focus:border-blue-600 focus:ring-0 transition-colors disabled:bg-slate-50"
                        @(Model.Stock == 0 && !Model.EsServicio ? "disabled" : "") />
                    </div>

                    <button onclick="agregarAlCarrito(@Model.Id, '@Model.Nombre', @Model.Precio.ToString().Replace(",", "."), @(Model.EsServicio.ToString().ToLower()))"
                        @(Model.Stock == 0 && !Model.EsServicio ? "disabled" : "")
                            class="flex-1 bg-blue-800 hover:bg-blue-700 disabled:bg-slate-300 disabled:cursor-not-allowed text-white font-bold py-3.5 px-6 rounded-xl shadow-lg hover:shadow-blue-800/30 transition-all flex items-center justify-center gap-3 text-lg group">
                        <i class="fas fa-shopping-cart group-hover:scale-110 transition-transform"></i>
                        <span>Añadir al Carrito</span>
                    </button>
                </div>

                <div class="grid grid-cols-2 gap-4 text-xs font-medium text-slate-500 bg-slate-50 rounded-xl p-4 border border-slate-100">
                    <div class="flex items-center gap-2.5">
                        <i class="fas fa-truck text-blue-600 text-base"></i>
                        <span>Envíos rápidos a Cochabamba y nivel nacional.</span>
                    </div>
                    <div class="flex items-center gap-2.5">
                        <i class="fas fa-shield-alt text-emerald-600 text-base"></i>
                        <span>Garantía de hardware y soporte asegurado.</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>