@using System.Security.Claims
@{
    ViewData["Title"] = "Carrito de Compras";
    // Capturamos el correo de la sesión si el usuario está autenticado
    var correoAutocompletado = User.Identity?.IsAuthenticated == true
        ? User.FindFirst(ClaimTypes.Email)?.Value ?? User.Identity.Name
        : "";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="flex text-sm text-slate-500 mb-6 font-medium" aria-label="Breadcrumb">
        <a asp-controller="Tienda" asp-action="Index" class="hover:text-blue-800 transition-colors flex items-center">
            <i class="fas fa-home mr-2"></i> Inicio
        </a>
        <span class="mx-3 text-slate-300">/</span>
        <span class="text-slate-800 font-bold">Mi Carrito</span>
    </nav>

    <div class="flex items-end justify-between mb-8 border-b border-slate-200 pb-4">
        <h1 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight flex items-center">
            <i class="fas fa-shopping-cart text-blue-800 mr-3"></i> Checkout
        </h1>
        <button onclick="vaciarCarrito()" class="hidden sm:flex text-sm text-slate-400 hover:text-rose-600 transition-colors items-center font-bold">
            <i class="fas fa-trash-alt mr-1.5"></i> Vaciar Carrito
        </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

        <div class="lg:col-span-7 xl:col-span-8 bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden min-h-[300px]" id="contenedor-carrito-items">
        </div>

        <div id="contenedor-totales" class="lg:col-span-5 xl:col-span-4 hidden">
            <div class="bg-white p-6 md:p-8 rounded-3xl shadow-lg border border-slate-200 sticky top-24">

                <h2 class="text-xl font-black text-slate-900 mb-6">Resumen de tu Orden</h2>

                <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100 mb-6 flex justify-between items-center">
                    <span class="text-slate-600 font-bold">Total a Pagar:</span>
                    <span id="total-carrito" class="text-3xl font-black text-blue-800 tracking-tight">Bs. 0.00</span>
                </div>

                <div class="space-y-5 border-t border-slate-100 pt-6">
                    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center mb-2">
                        <i class="fas fa-truck-fast mr-2"></i> Datos de Envío
                    </h3>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Correo Electrónico *</label>
                            <div class="relative">
                                <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                <input id="checkout-correo" type="email" required value="@correoAutocompletado" class="w-full pl-10 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700" placeholder="ejemplo@correo.com" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Teléfono de Contacto *</label>
                            <div class="relative">
                                <i class="fas fa-phone absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                <input id="checkout-telefono" type="tel" required class="w-full pl-10 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700" placeholder="Ej. 70000000" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Dirección de Entrega *</label>
                            <div class="relative">
                                <i class="fas fa-map-marker-alt absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                <input id="checkout-direccion" type="text" required class="w-full pl-10 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700" placeholder="Ej. Av. América Este #123" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Método de Pago *</label>
                            <div class="relative">
                                <i class="fas fa-wallet absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 z-10"></i>
                                <select id="checkout-metodopago" required class="w-full pl-10 pr-10 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-700 appearance-none relative">
                                    <option value="" class="text-slate-400">-- Selecciona tu método --</option>
                                    <option value="QR">Pago Rápido (Código QR)</option>
                                    <option value="Transferencia">Transferencia Bancaria</option>
                                    <option value="Efectivo">Efectivo contra entrega</option>
                                </select>
                                <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-8">
                    <button id="btn-checkout" onclick="procesarCheckout()" class="w-full py-4 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-black shadow-lg hover:shadow-emerald-600/30 transition-all flex items-center justify-center gap-2 text-lg group">
                        <i class="fas fa-lock group-hover:scale-110 transition-transform"></i> Finalizar Compra
                    </button>

                    <button onclick="vaciarCarrito()" class="w-full py-3 mt-2 text-sm text-slate-400 hover:text-rose-600 transition-colors font-bold sm:hidden">
                        Vaciar Todo el Carrito
                    </button>
                </div>

                <div class="mt-6 space-y-3 pt-6 border-t border-slate-100">
                    <div class="flex items-center gap-3 text-xs text-slate-500 font-medium">
                        <i class="fas fa-shield-alt text-blue-600 text-base w-5 text-center"></i>
                        <span>Checkout Seguro. Los datos de la sesión cuentan con encriptación y protección de identidad.</span>
                    </div>
                    <div class="flex items-center gap-3 text-xs text-slate-500 font-medium">
                        <i class="fas fa-box text-blue-600 text-base w-5 text-center"></i>
                        <span>Logística garantizada. Cobertura completa en Cochabamba y despachos al interior del país.</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>