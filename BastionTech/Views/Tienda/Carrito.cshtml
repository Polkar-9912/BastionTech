@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="max-w-4xl mx-auto my-8">
    <h1 class="text-3xl font-black text-slate-900 mb-8">Mi Carrito de Compras</h1>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

        <div id="contenedor-carrito-items">
            <div class="p-8 text-center text-slate-500">Cargando carrito...</div>
        </div>

        <div id="contenedor-totales" class="bg-slate-50 p-6 border-t border-slate-100 hidden">
            <div class="flex justify-between items-center mb-6">
                <span class="text-lg font-semibold text-slate-600">Total a pagar:</span>
                <span id="total-carrito" class="text-3xl font-black text-blue-800">$0.00</span>
            </div>

            <div class="flex justify-end gap-4">
                <button onclick="vaciarCarrito()" class="px-6 py-3 font-semibold text-slate-500 hover:bg-slate-200 rounded-lg transition-colors">
                    Vaciar carrito
                </button>
                <button id="btn-checkout" onclick="procesarCheckout()" class="px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-lg shadow-sm transition-colors text-lg">
                    Finalizar Compra
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const CLAVE_CARRITO = 'bastion_carrito';

        // 1. Iniciar el renderizado cuando cargue la página
        document.addEventListener('DOMContentLoaded', renderizarCarrito);

        // 2. Leer de la memoria y soportar AMBOS formatos (el de Detalle y el del Carrito)
        function obtenerCarrito() {
            const carrito = localStorage.getItem(CLAVE_CARRITO);
            if (!carrito) return [];

            const parseado = JSON.parse(carrito);

            return parseado.map(item => ({
                // Si existe productoId lo usa, si no, busca id
                id: item.productoId || item.id,
                nombre: item.nombre,
                // Si existe precioUnitario lo usa, si no, busca precio
                precio: item.precioUnitario !== undefined ? item.precioUnitario : item.precio,
                cantidad: item.cantidad,
                esServicio: item.esServicio
            }));
        }
        

        // 3. Guardar en memoria
        function guardarCarrito(carrito) {
            localStorage.setItem(CLAVE_CARRITO, JSON.stringify(carrito));
        }

        // 4. Pintar el HTML del carrito
        function renderizarCarrito() {
            const carrito = obtenerCarrito();
            const contenedor = document.getElementById('contenedor-carrito-items');
            const totales = document.getElementById('contenedor-totales');
            const totalLabel = document.getElementById('total-carrito');

            if (carrito.length === 0) {
                contenedor.innerHTML = '<div class="p-12 text-center text-slate-500 text-lg">Tu carrito está vacío. ¡Ve a la tienda a buscar algo genial! 🛒</div>';
                totales.classList.add('hidden');
                return;
            }

            totales.classList.remove('hidden');
            let html = '';
            let sumaTotal = 0;

            carrito.forEach(item => {
                const subtotal = item.precio * item.cantidad;
                sumaTotal += subtotal;

                // Construimos la fila de cada producto usando clases Tailwind
                html += `
                    <div class="flex items-center justify-between p-6 border-b border-slate-100 last:border-b-0 hover:bg-slate-50 transition-colors">
                        <div class="flex-1">
                            <h3 class="text-lg font-bold text-slate-800">${item.nombre}</h3>
                            <p class="text-sm font-medium ${item.esServicio ? 'text-purple-600' : 'text-slate-500'}">
                                ${item.esServicio ? '🔧 Servicio IT' : '📦 Hardware'}
                            </p>
                            <p class="text-slate-600 mt-1">Precio: $${item.precio.toFixed(2)} c/u</p>
                        </div>

                        <div class="flex items-center gap-6">
                            <div class="flex items-center bg-white border border-slate-200 rounded-lg shadow-sm">
                                <button onclick="actualizarCantidad(${item.id}, -1)" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-l-lg font-bold transition-colors">-</button>
                                <span class="px-4 font-bold text-slate-800">${item.cantidad}</span>
                                <button onclick="actualizarCantidad(${item.id}, 1)" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-r-lg font-bold transition-colors">+</button>
                            </div>

                            <div class="text-right w-24">
                                <span class="block font-black text-slate-800 text-lg">$${subtotal.toFixed(2)}</span>
                            </div>

                            <button onclick="eliminarItem(${item.id})" class="text-red-400 hover:text-red-600 hover:bg-red-50 p-2 rounded-lg transition-colors" title="Eliminar del carrito">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </div>
                    </div>
                `;
            });

            contenedor.innerHTML = html;
            totalLabel.innerText = '$' + sumaTotal.toFixed(2);
        }

        // 5. Lógica para los botones [+] y [-]
        function actualizarCantidad(id, cantidadCambio) {
            let carrito = obtenerCarrito();
            const index = carrito.findIndex(p => p.id === id);

            if (index !== -1) {
                carrito[index].cantidad += cantidadCambio;

                // Si la cantidad llega a 0, eliminamos el producto del carrito
                if (carrito[index].cantidad <= 0) {
                    carrito.splice(index, 1);
                }

                guardarCarrito(carrito);
                renderizarCarrito(); // Recargamos la vista visual
            }
        }

        // 6. Botón eliminar (el basurero)
        function eliminarItem(id) {
            let carrito = obtenerCarrito();
            carrito = carrito.filter(p => p.id !== id);
            guardarCarrito(carrito);
            renderizarCarrito();
        }

        // 7. Botón vaciar todo
        function vaciarCarrito() {
            if(confirm("¿Estás seguro de vaciar el carrito?")) {
                localStorage.removeItem(CLAVE_CARRITO);
                renderizarCarrito();
            }
        }

        // 8. LA CONEXIÓN CON TU C# BACKEND
        async function procesarCheckout() {
            const carrito = obtenerCarrito();
            if (carrito.length === 0) return;

            const btn = document.getElementById('btn-checkout');
            btn.disabled = true;
            btn.innerText = 'Procesando pago...';
            btn.classList.add('opacity-75');

            // Preparamos el objeto DTO idéntico al que espera C#
            const pedidoDTO = {
                ClienteId: "", // Si ya integraste Auth, aquí iría el UUID del usuario logueado
                TotalCalculado: 0,
                Items: carrito.map(item => ({
                    ProductoId: item.id,
                    Cantidad: item.cantidad,
                    PrecioUnitario: item.precio,
                    EsServicio: item.esServicio
                }))
            };

            try {
                const response = await fetch('/Tienda/ProcesarCheckout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(pedidoDTO)
                });

                const data = await response.json();

                if (response.ok) {
                    alert("¡Éxito! " + data.mensaje);
                    localStorage.removeItem(CLAVE_CARRITO); // Limpiamos tras comprar
                    window.location.href = '/Tienda/Index'; // Redirigimos al catálogo
                } else {
                    // Si el C# lanza error por falta de stock, caerá aquí
                    alert("Ups: " + data.mensaje);
                    btn.disabled = false;
                    btn.innerText = 'Finalizar Compra';
                    btn.classList.remove('opacity-75');
                }
            } catch (error) {
                console.error('Error conectando al servidor:', error);
                alert("Hubo un error de conexión con el servidor.");
                btn.disabled = false;
                btn.innerText = 'Finalizar Compra';
                btn.classList.remove('opacity-75');
            }
        }
    </script>
}