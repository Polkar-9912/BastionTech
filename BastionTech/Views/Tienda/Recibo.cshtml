@model BastionTech.Models.Venta
@{
    ViewData["Title"] = "Recibo de Compra";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 print:py-0 print:px-0 print:max-w-full">

    <!-- Migas de pan (Se ocultan al imprimir) -->
    <nav class="flex text-sm text-slate-500 mb-6 font-medium print:hidden" aria-label="Breadcrumb">
        <a asp-controller="Tienda" asp-action="Index" class="hover:text-blue-800 transition-colors flex items-center">
            <i class="fas fa-home mr-2"></i> Inicio
        </a>
        <span class="mx-3 text-slate-300">/</span>
        <a asp-controller="Tienda" asp-action="MisCompras" class="hover:text-blue-800 transition-colors">
            Mis Compras
        </a>
        <span class="mx-3 text-slate-300">/</span>
        <span class="text-slate-800 font-bold">Comprobante #@Model.Id</span>
    </nav>

    <!-- Contenedor del Comprobante -->
    <div class="bg-white shadow-xl rounded-3xl overflow-hidden border border-slate-200 print:shadow-none print:border-none print:rounded-none">

        <!-- Cabecera Corporativa -->
        <div class="bg-gradient-to-r from-slate-800 to-slate-900 px-8 py-10 text-white flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 print:bg-white print:text-slate-900 print:border-b print:border-slate-300">
            <div>
                <h1 class="text-3xl font-black tracking-tight flex items-center gap-3">
                    <i class="fas fa-shield-alt text-blue-400 print:text-slate-800"></i> BastionTech
                </h1>
                <p class="text-slate-400 text-sm mt-1 font-medium print:text-slate-500">Comprobante Electrónico de Orden</p>
            </div>
            <div class="sm:text-right">
                <p class="text-3xl font-black text-emerald-400 tracking-tight print:text-slate-800">Orden #@Model.Id</p>
                <p class="text-sm text-slate-300 font-medium print:text-slate-500 flex items-center sm:justify-end mt-1 gap-2">
                    <i class="far fa-calendar-alt"></i> @Model.FechaTransaccion.ToString("dd/MM/yyyy HH:mm")
                </p>
            </div>
        </div>

        <!-- Bloque de Datos del Cliente -->
        <div class="px-8 py-8 bg-slate-50 border-b border-slate-200 flex flex-col md:flex-row justify-between gap-8 print:bg-white">
            <div class="space-y-2.5 flex-1">
                <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4 flex items-center">
                    <i class="fas fa-user-tag mr-2"></i> Datos de Facturación y Envío
                </h3>
                <p class="text-sm text-slate-800 font-bold flex items-center gap-3">
                    <i class="fas fa-envelope text-slate-400 w-4 text-center"></i>
                    @(string.IsNullOrEmpty(Model.Correo) ? "No registrado" : Model.Correo)
                </p>
                <p class="text-sm text-slate-800 font-bold flex items-center gap-3">
                    <i class="fas fa-phone text-slate-400 w-4 text-center"></i>
                    @(string.IsNullOrEmpty(Model.Telefono) ? "No registrado" : Model.Telefono)
                </p>
                <p class="text-sm text-slate-800 font-bold flex items-center gap-3">
                    <i class="fas fa-map-marker-alt text-slate-400 w-4 text-center"></i>
                    @(string.IsNullOrEmpty(Model.Direccion) ? "No registrada" : Model.Direccion)
                </p>
            </div>

            <div class="md:text-right flex-shrink-0">
                <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-4">Método de Pago Seleccionado</h3>
                <span class="inline-flex items-center px-4 py-2 bg-white text-blue-800 text-sm font-black rounded-xl border-2 border-blue-100 shadow-sm print:border-slate-300 print:text-slate-800">
                    <i class="fas fa-wallet mr-2 text-blue-600 print:text-slate-600"></i>
                    @(string.IsNullOrEmpty(Model.MetodoPago) ? "No especificado" : Model.MetodoPago)
                </span>
            </div>
        </div>

        <!-- Instrucciones Dinámicas de Pago -->
        @if (Model.MetodoPago == "Efectivo")
        {
            <div class="bg-emerald-50 border-b border-emerald-100 p-8 flex flex-col sm:flex-row gap-6 items-center print:border-y print:border-slate-300 print:bg-white">
                <div class="w-16 h-16 bg-white rounded-2xl shadow-sm border border-emerald-200 flex items-center justify-center flex-shrink-0 print:border-slate-300">
                    <i class="fas fa-money-bill-wave text-3xl text-emerald-600 print:text-slate-800"></i>
                </div>
                <div>
                    <h3 class="text-lg font-black text-emerald-900 mb-1 print:text-slate-900">Pago contra entrega en Efectivo</h3>
                    <p class="text-sm text-emerald-700 font-medium leading-relaxed print:text-slate-700">
                        Ten preparado el monto exacto de <strong class="text-emerald-900 font-black text-base print:text-slate-900">Bs. @Model.Total.ToString("N2")</strong>. Nuestro equipo logístico se contactará al número registrado para coordinar el despacho seguro a tu ubicación.
                    </p>
                </div>
            </div>
        }
        else
        {
            <div class="bg-blue-50 border-b border-blue-100 p-8 flex flex-col md:flex-row gap-6 items-center print:border-y print:border-slate-300 print:bg-white">
                <div class="w-16 h-16 bg-white rounded-2xl shadow-sm border border-blue-200 flex items-center justify-center flex-shrink-0 print:border-slate-300">
                    <i class="fas @(Model.MetodoPago == "QR" ? "fa-qrcode" : "fa-university") text-3xl text-blue-700 print:text-slate-800"></i>
                </div>
                <div>
                    <h3 class="text-lg font-black text-blue-900 mb-2 print:text-slate-900">Instrucciones de Pago (@Model.MetodoPago)</h3>
                    <p class="text-sm text-blue-800 font-medium mb-3 print:text-slate-700">
                        Para confirmar tu compra y habilitar el despacho, @(Model.MetodoPago == "QR" ? "escanea nuestro código QR corporativo" : "realiza una transferencia bancaria") a la siguiente cuenta verificada:
                    </p>
                    <div class="bg-white p-4 rounded-xl border border-blue-100 inline-block shadow-sm print:border-slate-300">
                        <ul class="text-sm text-slate-700 font-bold space-y-1.5">
                            <li class="flex items-center gap-2"><i class="fas fa-university text-blue-500 w-4"></i> Banco Nacional de Bolivia (BNB)</li>
                            <li class="flex items-center gap-2"><i class="fas fa-hashtag text-blue-500 w-4"></i> Cuenta: 1000-4567-8901</li>
                            <li class="flex items-center gap-2"><i class="fas fa-user-tie text-blue-500 w-4"></i> Titular: BastionTech Solutions SRL</li>
                        </ul>
                    </div>
                </div>
            </div>
        }

        <!-- Detalle de Adquisición (Tabla de Productos) -->
        <div class="p-8">
            <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-6 flex items-center border-b border-slate-100 pb-4">
                <i class="fas fa-box-open mr-2 text-lg"></i> Detalle de Artículos Adquiridos
            </h3>

            <div class="space-y-4">
                @if (ViewBag.Detalles != null)
                {
                    foreach (var detalle in ViewBag.Detalles as List<BastionTech.Models.VentaDetalle>)
                    {
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-4 border-b border-slate-100 last:border-0 gap-4 group">
                            <div class="flex-1">
                                <p class="font-black text-slate-800 text-base">@detalle.Producto.Nombre</p>
                                <p class="text-sm text-slate-500 font-medium mt-1">
                                    <span class="bg-slate-100 px-2 py-0.5 rounded text-slate-600 font-bold mr-2">Cant: @detalle.Cantidad</span>
                                    x Bs. @detalle.PrecioUnitario.ToString("N2")
                                </p>

                                @if (detalle.Producto.EsServicio)
                                {
                                    <span class="inline-flex items-center mt-3 px-2.5 py-1 bg-purple-50 text-purple-700 border border-purple-200 text-xs font-bold rounded-lg print:border-slate-300 print:text-slate-600">
                                        <i class="fas fa-headset mr-1.5"></i> Ticket de Soporte Generado Automáticamente
                                    </span>
                                }
                            </div>
                            <div class="font-black text-slate-900 text-lg">
                                Bs. @((detalle.Cantidad * detalle.PrecioUnitario).ToString("N2"))
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Totales -->
            <div class="mt-8 pt-6 border-t-2 border-slate-200 flex justify-between items-center bg-slate-50 p-6 rounded-2xl print:bg-transparent print:border-t-4 print:border-slate-800 print:rounded-none print:px-0">
                <span class="text-lg font-black text-slate-600 uppercase tracking-wider">Total a Pagar</span>
                <span class="text-3xl md:text-4xl font-black text-blue-800 tracking-tight print:text-slate-900">Bs. @Model.Total.ToString("N2")</span>
            </div>

            <div class="text-center mt-8 text-xs font-bold text-slate-400 hidden print:block">
                ¡Gracias por confiar en BastionTech! Su infraestructura en las mejores manos.
            </div>
        </div>

        <!-- Botones de Acción (Se ocultan al imprimir) -->
        <div class="bg-white p-6 flex flex-col sm:flex-row justify-end gap-4 border-t border-slate-200 print:hidden">
            <button onclick="window.print()" class="px-8 py-3 bg-white border-2 border-slate-200 hover:border-blue-600 rounded-xl text-slate-700 hover:text-blue-700 font-bold shadow-sm transition-all flex items-center justify-center gap-2 group">
                <i class="fas fa-print group-hover:scale-110 transition-transform text-slate-400 group-hover:text-blue-600"></i> Imprimir / Guardar PDF
            </button>
            <a asp-controller="Tienda" asp-action="Index" class="px-8 py-3 bg-blue-800 hover:bg-blue-700 text-white rounded-xl font-bold shadow-lg hover:shadow-blue-800/30 transition-all flex items-center justify-center text-center">
                Volver a la Tienda
            </a>
        </div>
    </div>
</div>