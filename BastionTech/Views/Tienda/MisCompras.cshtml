@model BastionTech.Models.MisComprasViewModel
@{
    ViewData["Title"] = "Mis Compras";
}

<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8">

    <div class="mb-8 border-b border-slate-200 pb-5">
        <h1 class="text-3xl font-black text-slate-800 tracking-tight">
            <i class="fas fa-file-invoice-dollar text-blue-800 mr-2"></i>Historial Financiero
        </h1>
        <p class="text-slate-500 mt-2 text-sm font-medium">Gestiona y audita todos tus comprobantes de pago y adquisiciones en BastionTech.</p>
    </div>

    @if (Model.Compras == null || !Model.Compras.Any())
    {
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-12 text-center shadow-sm">
            <div class="w-24 h-24 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm border border-slate-100 mb-6">
                <i class="fas fa-box-open text-4xl text-slate-300"></i>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">Aún no tienes compras registradas</h3>
            <p class="text-slate-500 mb-8 max-w-md mx-auto">Tu historial está en blanco. Explora nuestro catálogo para encontrar el hardware o servicio IT que necesitas.</p>

            <a asp-controller="Tienda" asp-action="Index" class="inline-flex items-center px-6 py-3 bg-blue-800 hover:bg-blue-700 text-white rounded-xl font-bold shadow-sm transition-all">
                <i class="fas fa-store mr-2"></i> Ir a la Tienda
            </a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-slate-500 uppercase bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th scope="col" class="px-6 py-4 font-bold"># Orden</th>
                            <th scope="col" class="px-6 py-4 font-bold">Fecha de Compra</th>
                            <th scope="col" class="px-6 py-4 font-bold">Método de Pago</th>
                            <th scope="col" class="px-6 py-4 font-bold text-right">Monto Total</th>
                            <th scope="col" class="px-6 py-4 font-bold text-center">Auditoría</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var compra in Model.Compras)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4 font-black text-blue-800">
                                    #@compra.Id
                                </td>

                                <td class="px-6 py-4 text-slate-600 font-medium">
                                    @compra.FechaTransaccion.ToString("dd/MM/yyyy")
                                    <span class="text-xs text-slate-400 block">@compra.FechaTransaccion.ToString("HH:mm")</span>
                                </td>

                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 text-slate-700 border border-slate-200">
                                        <i class="fas fa-wallet mr-1.5 text-slate-400"></i>
                                        @(string.IsNullOrEmpty(compra.MetodoPago) ? "No especificado" : compra.MetodoPago)
                                    </span>
                                </td>

                                <td class="px-6 py-4 font-black text-slate-800 text-right text-base">
                                    Bs. @compra.Total.ToString("N2")
                                </td>

                                <td class="px-6 py-4 text-center">
                                    <a asp-controller="Tienda" asp-action="Recibo" asp-route-id="@compra.Id"
                                       class="inline-flex items-center justify-center px-3 py-1.5 bg-white border border-slate-300 rounded-lg text-slate-600 font-bold hover:bg-blue-50 hover:text-blue-700 hover:border-blue-200 transition-all text-xs shadow-sm">
                                        <i class="fas fa-file-pdf mr-1.5"></i> Ver Recibo
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="bg-slate-50 border-t border-slate-200 p-4 text-right">
                <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">
                    Total de registros históricos: @Model.Compras.Count
                </span>
            </div>
        </div>
        <div class="mt-8 bg-blue-50 border border-blue-100 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center flex-shrink-0 shadow-sm border border-blue-100">
                    <i class="fas fa-truck text-blue-600 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-800">¿Dudas sobre la entrega o despacho de tu hardware?</h3>
                    <p class="text-sm text-slate-600 mt-0.5">Póngase en contacto directo con nuestra área de Logística y Almacén para el seguimiento.</p>
                </div>
            </div>

            <a href="mailto:logistica@bastiontech.com?subject=Consulta%20sobre%20seguimiento%20de%20Orden"
               class="whitespace-nowrap px-5 py-2.5 bg-white border border-slate-300 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700 text-slate-700 rounded-lg text-sm font-bold shadow-sm transition-all flex items-center">
                <i class="fas fa-headset mr-2"></i> Contactar a Logística
            </a>
        </div>
    }
</div>