<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BastionTech</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-slate-50 font-sans text-slate-900 flex flex-col min-h-screen">

    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex-shrink-0 flex items-center">
                    <a asp-controller="Tienda" asp-action="Index" class="text-2xl font-black text-blue-800 tracking-tight">
                        Bastion<span class="text-slate-800">Tech</span>
                    </a>
                </div>

                <div class="flex items-center space-x-6">
                    @if (User.Identity == null || !User.Identity.IsAuthenticated || (!User.IsInRole("Admin") && !User.IsInRole("Tecnico")))
                    {
                        <a asp-controller="Tienda" asp-action="Carrito" class="relative p-2 text-slate-600 hover:text-blue-800 transition-colors">
                            <i class="fas fa-shopping-cart text-xl"></i>
                            <span id="contador-carrito" class="absolute top-0 right-0 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-bold leading-none text-white transform translate-x-1/4 -translate-y-1/4 bg-rose-500 rounded-full">0</span>
                        </a>

                        <a asp-controller="Tienda" asp-action="AbrirTicket" class="text-sm font-bold text-slate-600 hover:text-blue-800 transition-colors">
                            <i class="fas fa-headset mr-1"></i> Soporte
                        </a>
                        <a asp-controller="Tienda" asp-action="MisCompras" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-blue-700 transition-colors font-medium">
                            <i class="fas fa-file-invoice-dollar mr-2 w-4 text-center text-slate-400"></i> Mis Compras
                        </a>
                    }

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin") || User.IsInRole("Tecnico"))
                        {
                            <a asp-controller="Admin" asp-action="Dashboard" class="text-sm font-bold text-emerald-600 hover:text-emerald-700">
                                <i class="fas fa-shield-alt mr-1"></i> Dashboard
                            </a>
                        }

                        <span class="text-sm font-medium text-slate-600 hidden md:inline-block">Hola, @User.Identity.Name</span>

                        <a asp-controller="Account" asp-action="Logout" class="hidden sm:inline-flex items-center justify-center px-4 py-2 border border-slate-200 text-sm font-medium rounded-md text-slate-600 bg-white hover:bg-slate-50 shadow-sm transition-colors" onclick="cerrarSesionSupabase()">
                            Salir
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="hidden sm:inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-800 hover:bg-blue-700 shadow-sm transition-colors">
                            Iniciar Sesión
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-8">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-slate-200 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-center text-slate-500 text-sm">
            &copy; @DateTime.Now.Year - BastionTech | Protegiendo y equipando tu infraestructura.
        </div>
    </footer>

    <script src="~/js/carrito.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/@@supabase/supabase-js@2"></script>

    <script>
        const supabaseClient = window.supabase.createClient(
        'https://wlmtqvcmpghqpolfhxsf.supabase.co',
        'sb_publishable_xAU29nfuXniuLR7dBL3WwA_rWxw5WKW'
        );

        async function cerrarSesionSupabase() {
        await supabaseClient.auth.signOut();
        localStorage.removeItem(CLAVE_CARRITO);
        }
    </script>
</body>
</html>