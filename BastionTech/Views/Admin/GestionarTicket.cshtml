@model BastionTech.Models.TicketServicio
@{
    ViewData["Title"] = "Diagnóstico de Ticket";
}

<div class="min-h-screen bg-slate-50 flex -mt-8 -mx-4 sm:-mx-6 lg:-mx-8">

    <!-- ========================================== -->
    <!-- SIDEBAR (Menú Lateral Oscuro)              -->
    <!-- ========================================== -->
    <aside class="w-72 bg-slate-900 text-white flex-col hidden md:flex rounded-br-3xl shadow-2xl relative z-10">
        <div class="p-8 border-b border-slate-800">
            <h2 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">
                <i class="fas fa-shield-halved text-blue-500"></i> Bastion<span class="text-blue-500">Tech</span>
            </h2>
            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mt-2">Centro de Operaciones IT</p>
            <div class="mt-4 inline-flex items-center px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-xs font-medium text-emerald-400">
                <i class="fas fa-circle text-[8px] mr-2 animate-pulse"></i> @(User.IsInRole("Admin") ? "Administrador" : "Soporte Técnico")
            </div>
        </div>

        <nav class="flex-grow p-4 space-y-1.5 mt-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-chart-line w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Resumen Operativo
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Inventario" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                    <i class="fas fa-server w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Inventario de Hardware
                </a>
                <a asp-controller="Admin" asp-action="Reportes" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                    <i class="fas fa-file-contract w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Reportes Financieros
                </a>
            }

            <!-- PESTAÑA ACTIVA -->
            <a asp-controller="Admin" asp-action="Tickets" class="block w-full text-left px-4 py-3.5 bg-blue-600 rounded-xl text-sm font-bold text-white shadow-lg shadow-blue-900/50 transition-all flex items-center">
                <i class="fas fa-headset w-6 text-blue-200"></i> Mesa de Ayuda (Tickets)
            </a>
        </nav>

        <div class="p-6 border-t border-slate-800">
            <a asp-controller="Tienda" asp-action="Index" class="flex items-center text-xs text-slate-400 hover:text-white transition-colors font-medium">
                <i class="fas fa-external-link-alt mr-2"></i> Ver Tienda Pública
            </a>
        </div>
    </aside>

    <!-- ========================================== -->
    <!-- CONTENIDO PRINCIPAL                        -->
    <!-- ========================================== -->
    <main class="flex-1 p-8 lg:p-12 overflow-y-auto w-full">

        <!-- Cabecera y Botón de Retorno -->
        <div class="mb-8 border-b border-slate-200 pb-6 flex items-center gap-5">
            <a asp-action="Tickets" class="w-14 h-14 rounded-2xl bg-white border-2 border-slate-200 flex items-center justify-center text-slate-400 hover:text-blue-700 hover:border-blue-400 hover:bg-blue-50 transition-all shadow-sm flex-shrink-0 group">
                <i class="fas fa-arrow-left text-xl group-hover:-translate-x-1 transition-transform"></i>
            </a>

            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Orden de Trabajo #@Model.Id</h1>
                <p class="text-sm md:text-base text-slate-500 mt-1 font-medium">Apertura del caso: <span class="font-bold text-slate-700">@Model.FechaCreacion.ToString("dd MMMM, yyyy - HH:mm")</span></p>
            </div>
        </div>

        <div class="max-w-4xl mx-auto xl:mx-0">
            <!-- Panel de Comunicación (Estilo SOC) -->
            @if (!string.IsNullOrEmpty(Model.Telefono))
            {
                <div class="bg-gradient-to-r from-slate-800 to-slate-900 text-white p-6 md:p-8 rounded-3xl shadow-xl border border-slate-800 mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                    <div>
                        <span class="text-[10px] font-black text-emerald-400 uppercase tracking-widest bg-emerald-400/10 px-3 py-1 rounded-full border border-emerald-400/20">Canal de Comunicación Directa</span>
                        <h3 class="text-2xl font-black mt-3 flex items-center"><i class="fas fa-user-circle mr-3 text-slate-400 text-3xl"></i> Datos del Solicitante</h3>
                        <p class="text-slate-300 text-sm mt-2 ml-11 font-medium">Número registrado: <span class="font-bold text-white text-base tracking-wide">@Model.Telefono</span></p>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                        <a href="tel:@Model.Telefono" class="px-6 py-3.5 bg-slate-700 hover:bg-slate-600 border border-slate-600 rounded-xl text-sm font-bold transition-colors flex items-center justify-center shadow-sm w-full sm:w-auto">
                            <i class="fas fa-phone-alt mr-2"></i> Llamada
                        </a>
                        <a href="https://wa.me/@Model.Telefono.Replace(" ", "").Replace("+", "").Replace("-", "")" target="_blank" class="px-6 py-3.5 bg-emerald-600 hover:bg-emerald-500 border border-emerald-500 rounded-xl text-sm font-black transition-colors flex items-center justify-center shadow-lg shadow-emerald-900/30 w-full sm:w-auto group">
                            <i class="fab fa-whatsapp mr-2 text-lg group-hover:scale-110 transition-transform"></i> WhatsApp
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="bg-amber-50 text-amber-800 p-6 rounded-3xl border-2 border-amber-200 mb-8 flex items-start md:items-center gap-4">
                    <div class="w-12 h-12 bg-amber-200/50 text-amber-600 rounded-2xl flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-exclamation-triangle text-xl"></i>
                    </div>
                    <div>
                        <h4 class="font-black text-amber-900 text-lg">Sin información de contacto directo</h4>
                        <p class="text-sm text-amber-700 font-medium mt-0.5">Este ticket fue generado automáticamente por el sistema al adquirir un servicio, o el usuario omitió el número de teléfono.</p>
                    </div>
                </div>
            }

            <!-- Formulario Principal del Ticket -->
            <form asp-action="GestionarTicket" method="post" class="bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-slate-200">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="VentaDetalleId" />
                <input type="hidden" asp-for="ClienteId" />
                <input type="hidden" asp-for="FechaCreacion" />
                <input type="hidden" asp-for="Telefono" />
                <input type="hidden" asp-for="Asunto" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="md:col-span-1">
                            <label asp-for="TecnicoAsignadoId" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Especialista de Soporte</label>
                            <div class="relative">
                                <i class="fas fa-user-tie absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 z-10"></i>
                                <select asp-for="TecnicoAsignadoId" class="w-full pl-11 pr-10 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800 appearance-none relative">
                                    <option value="">-- Bolsa de Trabajo (Sin Asignar) --</option>
                                    @if (ViewBag.Tecnicos != null)
                                    {
                                        foreach (var tecnico in ViewBag.Tecnicos as List<BastionTech.Models.Usuario>)
                                        {
                                            <option value="@tecnico.Id">@tecnico.NombreCompleto</option>
                                        }
                                    }
                                </select>
                                <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                            </div>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="TecnicoAsignadoId" />
                    }

                    <div class="@(User.IsInRole("Admin") ? "md:col-span-1" : "md:col-span-2")">
                        <label asp-for="EstadoTicket" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Estado Operativo</label>
                        <div class="relative">
                            <i class="fas fa-tasks absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 z-10"></i>
                            <select asp-for="EstadoTicket" class="w-full pl-11 pr-10 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-black text-slate-800 appearance-none relative">
                                <option value="Pendiente">🔴 Pendiente (En espera)</option>
                                <option value="En Proceso">🔵 En Proceso (Trabajando)</option>
                                <option value="Resuelto">🟢 Resuelto (Finalizado)</option>
                            </select>
                            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                        </div>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="NotasTecnicas" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Bitácora y Notas Técnicas</label>
                        <div class="relative">
                            <i class="fas fa-clipboard-list absolute left-4 top-4 text-slate-400"></i>
                            <textarea asp-for="NotasTecnicas" rows="6" placeholder="Escribe aquí las observaciones del hardware, reportes de reparación o justificaciones técnicas..." class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700 resize-y"></textarea>
                        </div>
                    </div>
                </div>

                <div class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row justify-end gap-4">
                    <a asp-action="Tickets" class="px-6 py-3.5 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-slate-600 font-bold shadow-sm transition-all text-center">Cancelar</a>
                    <button type="submit" class="px-8 py-3.5 bg-blue-800 hover:bg-blue-700 text-white rounded-xl font-black shadow-lg hover:shadow-blue-800/30 transition-all flex items-center justify-center gap-2 group">
                        <i class="fas fa-save group-hover:scale-110 transition-transform"></i> Guardar Reporte
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>