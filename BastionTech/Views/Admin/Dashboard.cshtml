@{
    ViewData["Title"] = "Panel de Control";
}

<div class="min-h-screen bg-slate-50 flex">

    <aside class="w-64 bg-slate-900 text-white flex flex-col hidden md:flex rounded-br-2xl shadow-xl">
        <div class="p-6 border-b border-slate-800">
            <h2 class="text-xl font-black text-emerald-400 tracking-tight">Centro de Mando</h2>
            <p class="text-xs text-slate-400 mt-1">Rol: @(User.IsInRole("Admin") ? "Administrador" : "Soporte Técnico")</p>
        </div>

        <nav class="flex-grow p-4 space-y-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="block w-full text-left px-4 py-3 bg-blue-800 rounded-lg text-sm font-medium text-white transition-colors">
                <i class="fas fa-chart-line w-6"></i> Resumen
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Inventario" class="block w-full text-left px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg text-sm font-medium transition-colors">
                    <i class="fas fa-box w-6"></i> Inventario
                </a>
            }

            <a href="#" class="block w-full text-left px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg text-sm font-medium transition-colors">
                <i class="fas fa-ticket-alt w-6"></i> Mis Tickets Asignados
            </a>
        </nav>
    </aside>

    <main class="flex-1 p-8">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-black text-slate-800">Resumen Operativo</h1>
                <p class="text-sm text-slate-500 mt-1">Bienvenido al sistema, @User.Identity.Name</p>
            </div>
            <span class="px-4 py-2 bg-white rounded-full shadow-sm text-sm font-bold text-slate-500 h-fit">
                <i class="fas fa-calendar-day mr-2 text-blue-600"></i> @DateTime.Now.ToString("dd MMMM, yyyy")
            </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

            @if (User.IsInRole("Admin"))
            {
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center">
                    <div class="p-4 bg-emerald-100 text-emerald-600 rounded-xl mr-4"><i class="fas fa-dollar-sign text-2xl"></i></div>
                    <div><p class="text-sm text-slate-500 font-medium">Ingresos Totales</p><h3 class="text-2xl font-black text-slate-800">--</h3></div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center">
                    <div class="p-4 bg-blue-100 text-blue-600 rounded-xl mr-4"><i class="fas fa-shopping-cart text-2xl"></i></div>
                    <div><p class="text-sm text-slate-500 font-medium">Ventas Realizadas</p><h3 class="text-2xl font-black text-slate-800">--</h3></div>
                </div>
            }

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center @(User.IsInRole("Tecnico") ? "md:col-span-3" : "")">
                <div class="p-4 bg-rose-100 text-rose-600 rounded-xl mr-4"><i class="fas fa-wrench text-2xl"></i></div>
                <div><p class="text-sm text-slate-500 font-medium">Tickets Abiertos bajo mi Supervisión</p><h3 class="text-2xl font-black text-slate-800">--</h3></div>
            </div>

        </div>
    </main>
</div>