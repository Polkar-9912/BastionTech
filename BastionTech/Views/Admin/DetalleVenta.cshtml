@model IEnumerable<BastionTech.Models.VentaDetalle>
@{
    ViewData["Title"] = "Detalle de Transacción";
}

<div class="min-h-screen bg-slate-50 flex -mt-8 -mx-4 sm:-mx-6 lg:-mx-8">

    <!-- ========================================== -->
    <!-- SIDEBAR (Menú Lateral Oscuro)              -->
    <!-- ========================================== -->
    <aside class="w-72 bg-slate-900 text-white flex-col hidden md:flex rounded-br-3xl shadow-2xl relative z-10">
        <div class="p-8 border-b border-slate-800">
            <h2 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">
                <i class="fas fa-shield-halved text-blue-500"></i> Bastion<span class="text-blue-500">Tech</span>
            </h2>
            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mt-2">Centro de Operaciones IT</p>
            <div class="mt-4 inline-flex items-center px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-xs font-medium text-emerald-400">
                <i class="fas fa-circle text-[8px] mr-2 animate-pulse"></i> @(User.IsInRole("Admin") ? "Administrador" : "Soporte Técnico")
            </div>
        </div>

        <nav class="flex-grow p-4 space-y-1.5 mt-2">
            <!-- PESTAÑA ACTIVA (Porque venimos del Dashboard) -->
            <a asp-controller="Admin" asp-action="Dashboard" class="block w-full text-left px-4 py-3.5 bg-blue-600 rounded-xl text-sm font-bold text-white shadow-lg shadow-blue-900/50 transition-all flex items-center">
                <i class="fas fa-chart-line w-6 text-blue-200"></i> Resumen Operativo
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Inventario" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                    <i class="fas fa-server w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Inventario de Hardware
                </a>
                <a asp-controller="Admin" asp-action="Reportes" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                    <i class="fas fa-file-contract w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Reportes Financieros
                </a>
            }

            <a asp-controller="Admin" asp-action="Tickets" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-headset w-6 text-slate-500 group-hover:text-purple-400 transition-colors"></i> Mesa de Ayuda (Tickets)
            </a>
        </nav>

        <div class="p-6 border-t border-slate-800">
            <a asp-controller="Tienda" asp-action="Index" class="flex items-center text-xs text-slate-400 hover:text-white transition-colors font-medium">
                <i class="fas fa-external-link-alt mr-2"></i> Ver Tienda Pública
            </a>
        </div>
    </aside>

    <!-- ========================================== -->
    <!-- CONTENIDO PRINCIPAL                        -->
    <!-- ========================================== -->
    <main class="flex-1 p-8 lg:p-12 overflow-y-auto w-full">

        <!-- Cabecera y Botón de Retorno -->
        <div class="mb-10 border-b border-slate-200 pb-6 flex items-center gap-5">
            <!-- Botón Back Moderno -->
            <a asp-action="Dashboard" class="w-14 h-14 rounded-2xl bg-white border-2 border-slate-200 flex items-center justify-center text-slate-400 hover:text-blue-700 hover:border-blue-400 hover:bg-blue-50 transition-all shadow-sm flex-shrink-0 group">
                <i class="fas fa-arrow-left text-xl group-hover:-translate-x-1 transition-transform"></i>
            </a>

            <div>
                <div class="flex items-center gap-3">
                    <h1 class="text-3xl font-black text-slate-900 tracking-tight">Transacción #@ViewBag.VentaId</h1>
                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-slate-800 text-white shadow-sm">
                        Auditoría
                    </span>
                </div>
                <p class="text-sm md:text-base text-slate-500 mt-1.5 font-medium">Desglose técnico de artículos y servicios facturados en la orden.</p>
            </div>
        </div>

        <!-- Tabla de Detalle -->
        <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden max-w-5xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200 text-slate-400 text-[11px] uppercase tracking-wider font-black">
                            <th class="p-6">Producto / Servicio Adquirido</th>
                            <th class="p-6 text-center">Cantidad</th>
                            <th class="p-6 text-right">Precio Unitario</th>
                            <th class="p-6 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
                        @{
                            decimal totalGeneral = 0;
                        }
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var subtotal = item.Cantidad * item.PrecioUnitario;
                                totalGeneral += subtotal;

                                <tr class="hover:bg-blue-50/50 transition-colors group">
                                    <td class="p-6 font-bold text-slate-800">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center border border-slate-200 group-hover:bg-white transition-colors">
                                                <i class="fas @(item.Producto?.EsServicio == true ? "fa-headset text-purple-600" : "fa-box text-blue-600")"></i>
                                            </div>
                                            <span>@(item.Producto?.Nombre ?? "Producto Descatalogado")</span>
                                        </div>
                                    </td>

                                    <td class="p-6 text-center">
                                        <span class="inline-flex items-center justify-center min-w-[36px] h-[36px] px-2 rounded-lg bg-slate-100 border border-slate-200 font-bold text-slate-700">
                                            @item.Cantidad
                                        </span>
                                    </td>

                                    <td class="p-6 text-right text-slate-500 font-medium text-base">
                                        Bs. @item.PrecioUnitario.ToString("N2")
                                    </td>

                                    <td class="p-6 text-right font-black text-slate-800 text-base">
                                        Bs. @subtotal.ToString("N2")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="p-12 text-center text-slate-400 font-medium">
                                    <i class="fas fa-file-invoice-dollar text-4xl mb-3 text-slate-200 block"></i>
                                    No hay detalles registrados para esta transacción.
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-slate-50 border-t border-slate-200">
                        <tr>
                            <td colspan="3" class="p-6 text-right font-black text-slate-500 uppercase text-xs tracking-wider border-r border-slate-200">
                                Total General Facturado
                            </td>
                            <td class="p-6 text-right font-black text-blue-800 text-2xl tracking-tight">
                                Bs. @totalGeneral.ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="bg-white border-t border-slate-200 p-5 flex justify-between items-center">
                <span class="text-xs font-bold text-slate-400 flex items-center gap-2">
                    <i class="fas fa-lock text-slate-300"></i> Registro Inmutable en Base de Datos
                </span>
                <a asp-controller="Tienda" asp-action="Recibo" asp-route-id="@ViewBag.VentaId" target="_blank" class="px-5 py-2.5 bg-white border border-slate-200 hover:border-blue-400 text-slate-600 hover:text-blue-700 hover:bg-blue-50 rounded-xl text-xs font-bold shadow-sm transition-all flex items-center gap-2">
                    <i class="fas fa-file-pdf"></i> Ver Factura Digital
                </a>
            </div>
        </div>
    </main>
</div>