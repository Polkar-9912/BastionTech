@model IEnumerable<BastionTech.Models.TicketServicio>
@{
    ViewData["Title"] = "Gestión de Tickets";
}

<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-3xl font-black text-slate-800">Centro de Soporte Técnico</h1>
            <p class="text-sm text-slate-500 mt-1">Bandeja de servicios IT pendientes y en proceso</p>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-700 p-4 mb-6 rounded-r-lg shadow-sm flex items-center">
            <i class="fas fa-check-circle text-xl mr-3"></i>
            <p class="font-medium">@TempData["MensajeExito"]</p>
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
                        <th class="p-4 font-bold">Nº Ticket</th>
                        <th class="p-4 font-bold">Fecha de Creación</th>
                        <th class="p-4 font-bold text-center">Estado</th>
                        <th class="p-4 font-bold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var ticket in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="p-4 font-bold text-slate-800">#@ticket.Id</td>
                            <td class="p-4 text-slate-600">@ticket.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="p-4 text-center">
                                @if (ticket.EstadoTicket == "Resuelto")
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 border border-emerald-200">Resuelto</span>
                                }
                                else if (ticket.EstadoTicket == "En Proceso")
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-800 border border-blue-200">En Proceso</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-rose-100 text-rose-800 border border-rose-200">Pendiente</span>
                                }
                            </td>
                            <td class="p-4 text-center">
                                <a asp-action="GestionarTicket" asp-route-id="@ticket.Id" class="text-blue-600 hover:text-blue-800 font-bold px-4 py-2 hover:bg-blue-50 rounded-lg transition-colors">
                                    <i class="fas fa-wrench mr-2"></i> Diagnóstico
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>