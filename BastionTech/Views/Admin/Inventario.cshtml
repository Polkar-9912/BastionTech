@model IEnumerable<BastionTech.Models.Producto>
@{
    ViewData["Title"] = "Gestión de Inventario";
}

<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-3xl font-black text-slate-800">Catálogo de Productos</h1>
            <p class="text-sm text-slate-500 mt-1">Gestión centralizada de hardware y servicios IT</p>
        </div>
        <a asp-action="CrearProducto" class="bg-blue-800 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg font-bold shadow-sm transition-colors flex items-center">
            <i class="fas fa-plus mr-2"></i> Nuevo Artículo
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-700 p-4 mb-6 rounded-r-lg shadow-sm flex items-center">
            <i class="fas fa-check-circle text-xl mr-3"></i>
            <p class="font-medium">@TempData["MensajeExito"]</p>
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
                        <th class="p-4 font-bold">ID</th>
                        <th class="p-4 font-bold">Nombre del Artículo</th>
                        <th class="p-4 font-bold text-center">Tipo</th>
                        <th class="p-4 font-bold text-right">Precio</th>
                        <th class="p-4 font-bold text-center">Stock</th>
                        <th class="p-4 font-bold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="p-4 text-slate-400 font-medium whitespace-nowrap">#@item.Id</td>
                            <td class="p-4 font-bold text-slate-800">@item.Nombre</td>
                            <td class="p-4 text-center">
                                @if (item.EsServicio)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-purple-100 text-purple-800 border border-purple-200">
                                        Servicio IT
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-800 border border-blue-200">
                                        Hardware
                                    </span>
                                }
                            </td>
                            <td class="p-4 text-right font-black text-slate-700 whitespace-nowrap">$@item.Precio.ToString("0.00")</td>
                            <td class="p-4 text-center">
                                @if (item.EsServicio)
                                {
                                    <span class="text-slate-300">-</span>
                                }
                                else
                                {
                                    <span class="font-bold px-3 py-1 rounded-full text-xs
                                        @(item.Stock > 10 ? "bg-emerald-100 text-emerald-700" :
                                            item.Stock > 0 ? "bg-amber-100 text-amber-700" : "bg-rose-100 text-rose-700")">
                                        @item.Stock unid.
                                    </span>
                                }
                            </td>
                            <td class="p-4 text-center space-x-4 whitespace-nowrap">
                                <a asp-action="EditarProducto" asp-route-id="@item.Id" class="text-blue-500 hover:text-blue-700 transition-colors inline-block" title="Editar">
                                    <i class="fas fa-edit text-lg"></i>
                                </a>
                                <form asp-action="EliminarProducto" asp-route-id="@item.Id" method="post" class="inline-block" onsubmit="return confirm('ATENCIÓN: ¿Estás completamente seguro de borrar este artículo? Esto podría afectar el historial de ventas.');">
                                    <button type="submit" class="text-rose-400 hover:text-rose-600 transition-colors" title="Eliminar">
                                        <i class="fas fa-trash-alt text-lg"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>