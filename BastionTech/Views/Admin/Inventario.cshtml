@model IEnumerable<BastionTech.Models.Producto>
@{
    ViewData["Title"] = "Gestión de Inventario";
}

<div class="min-h-screen bg-slate-50 flex -mt-8 -mx-4 sm:-mx-6 lg:-mx-8">

    <aside class="w-72 bg-slate-900 text-white flex-col hidden md:flex rounded-br-3xl shadow-2xl relative z-10">
        <div class="p-8 border-b border-slate-800">
            <h2 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">
                <i class="fas fa-shield-halved text-blue-500"></i> Bastion<span class="text-blue-500">Tech</span>
            </h2>
            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mt-2">Centro de Operaciones IT</p>
            <div class="mt-4 inline-flex items-center px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-xs font-medium text-emerald-400">
                <i class="fas fa-circle text-[8px] mr-2 animate-pulse"></i> Administrador
            </div>
        </div>

        <nav class="flex-grow p-4 space-y-1.5 mt-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-chart-line w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Resumen Operativo
            </a>

            <a asp-controller="Admin" asp-action="Inventario" class="block w-full text-left px-4 py-3.5 bg-blue-600 rounded-xl text-sm font-bold text-white shadow-lg shadow-blue-900/50 transition-all flex items-center">
                <i class="fas fa-server w-6 text-blue-200"></i> Inventario de Hardware
            </a>

            <a asp-controller="Admin" asp-action="Reportes" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-file-contract w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Reportes Financieros
            </a>

            <a asp-controller="Admin" asp-action="Tickets" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-headset w-6 text-slate-500 group-hover:text-purple-400 transition-colors"></i> Mesa de Ayuda (Tickets)
            </a>
        </nav>
    </aside>

    <main class="flex-1 p-8 lg:p-12 overflow-y-auto">

        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Inventario</h1>
                <p class="text-sm text-slate-500 mt-1 font-medium">Gestión centralizada de hardware y servicios IT</p>
            </div>
            <a asp-action="CrearProducto" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-3 rounded-xl font-black shadow-lg shadow-emerald-600/20 transition-all flex items-center">
                <i class="fas fa-plus mr-2"></i> Nuevo Artículo
            </a>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-700 p-4 mb-8 rounded-r-xl shadow-sm flex items-center font-bold">
                <i class="fas fa-check-circle text-xl mr-3"></i> @TempData["MensajeExito"]
            </div>
        }

        <div class="bg-white p-4 rounded-3xl shadow-sm border border-slate-200 mb-8">
            <form method="get" asp-action="Inventario" id="form-busqueda" class="flex items-center gap-3 w-full max-w-xl">
                <div class="relative flex-1">
                    <i class="fas fa-search text-slate-400 absolute left-4 top-1/2 -translate-y-1/2"></i>
                    <input type="text" name="terminoBusqueda" id="input-busqueda" value="@ViewBag.TerminoActual"
                           placeholder="Buscar por nombre de producto..."
                           class="w-full pl-11 pr-4 py-3.5 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 font-bold text-slate-700 transition-all" />
                </div>

                <button type="button" id="btn-voz" title="Buscar por voz"
                        class="w-[52px] h-[52px] bg-slate-100 text-slate-600 border-2 border-slate-200 rounded-xl flex items-center justify-center transition-all cursor-pointer relative group">
                    <i class="fas fa-microphone text-lg" id="icono-microfono"></i>
                    <span id="pulso-grabando" class="absolute inset-0 rounded-xl bg-rose-500/20 animate-ping hidden"></span>
                </button>

                @if (!string.IsNullOrWhiteSpace(ViewBag.TerminoActual))
                {
                    <a asp-action="Inventario" class="text-xs font-black text-slate-400 hover:text-rose-500 transition-colors uppercase">Limpiar</a>
                }
            </form>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200 text-slate-400 text-[11px] uppercase tracking-wider font-black">
                            <th class="p-5">ID</th>
                            <th class="p-5">Nombre del Artículo</th>
                            <th class="p-5 text-center">Tipo</th>
                            <th class="p-5 text-right">Precio</th>
                            <th class="p-5 text-center">Stock</th>
                            <th class="p-5 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="hover:bg-blue-50/50 transition-colors group">
                                    <td class="p-5 font-black text-slate-400">#@item.Id</td>
                                    <td class="p-5 font-bold text-slate-800">@item.Nombre</td>
                                    <td class="p-5 text-center">
                                        <span class="inline-flex items-center px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider @(item.EsServicio ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700")">
                                            @(item.EsServicio ? "Servicio IT" : "Hardware")
                                        </span>
                                    </td>
                                    <td class="p-5 text-right font-black text-slate-800">Bs. @item.Precio.ToString("N2")</td>
                                    <td class="p-5 text-center">
                                        @if (item.EsServicio)
                                        {
                                            <span class="text-slate-300 font-black">—</span>
                                        }
                                        else
                                        {
                                            <span class="font-black px-3 py-1 rounded-lg text-[11px] @(item.Stock > 10 ? "bg-emerald-100 text-emerald-700" : item.Stock > 0 ? "bg-amber-100 text-amber-700" : "bg-rose-100 text-rose-700")">
                                                @item.Stock unid.
                                            </span>
                                        }
                                    </td>
                                    <td class="p-5 text-center">
                                        <div class="flex justify-center gap-2">
                                            <a asp-action="EditarProducto" asp-route-id="@item.Id" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form asp-action="EliminarProducto" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Seguro?');">
                                                <button type="submit" class="p-2 text-rose-400 hover:bg-rose-50 rounded-lg transition-colors">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="p-16 text-center text-slate-400 font-bold">
                                    <i class="fas fa-search text-3xl mb-3 block text-slate-300"></i> No hay productos encontrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SpeechRecognition) {
            const btnVoz = document.getElementById('btn-voz');
            if (btnVoz) btnVoz.style.display = 'none';
            return;
        }

        const recognition = new SpeechRecognition();
        recognition.lang = 'es-BO';
        const btnVoz = document.getElementById('btn-voz');
        const iconoMicrofono = document.getElementById('icono-microfono');
        const pulsoGrabando = document.getElementById('pulso-grabando');
        const inputBusqueda = document.getElementById('input-busqueda');
        const formBusqueda = document.getElementById('form-busqueda');

        btnVoz.addEventListener('click', () => recognition.start());

        recognition.onstart = () => {
            btnVoz.classList.add('bg-rose-500', 'text-white', 'border-rose-600');
            pulsoGrabando.classList.remove('hidden');
            inputBusqueda.placeholder = "Escuchando...";
        };

        recognition.onend = () => {
            btnVoz.classList.remove('bg-rose-500', 'text-white', 'border-rose-600');
            pulsoGrabando.classList.add('hidden');
            inputBusqueda.placeholder = "Buscar por nombre...";
        };

        recognition.onresult = (event) => {
            inputBusqueda.value = event.results[0][0].transcript.replace(/\./g, '');
            formBusqueda.submit();
        };
    });
</script>