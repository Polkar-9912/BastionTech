@model BastionTech.Models.Producto
@{
    ViewData["Title"] = "Editar Artículo";
}

<div class="min-h-screen bg-slate-50 flex -mt-8 -mx-4 sm:-mx-6 lg:-mx-8">

    <!-- ========================================== -->
    <!-- SIDEBAR (Menú Lateral Oscuro)              -->
    <!-- ========================================== -->
    <aside class="w-72 bg-slate-900 text-white flex-col hidden md:flex rounded-br-3xl shadow-2xl relative z-10">
        <div class="p-8 border-b border-slate-800">
            <h2 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">
                <i class="fas fa-shield-halved text-blue-500"></i> Bastion<span class="text-blue-500">Tech</span>
            </h2>
            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mt-2">Centro de Operaciones IT</p>
            <div class="mt-4 inline-flex items-center px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-xs font-medium text-emerald-400">
                <i class="fas fa-circle text-[8px] mr-2 animate-pulse"></i> Administrador
            </div>
        </div>

        <nav class="flex-grow p-4 space-y-1.5 mt-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-chart-line w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Resumen Operativo
            </a>

            <!-- PESTAÑA ACTIVA -->
            <a asp-controller="Admin" asp-action="Inventario" class="block w-full text-left px-4 py-3.5 bg-blue-600 rounded-xl text-sm font-bold text-white shadow-lg shadow-blue-900/50 transition-all flex items-center">
                <i class="fas fa-server w-6 text-blue-200"></i> Inventario de Hardware
            </a>

            <a asp-controller="Admin" asp-action="Reportes" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-file-contract w-6 text-slate-500 group-hover:text-blue-400 transition-colors"></i> Reportes Financieros
            </a>

            <a asp-controller="Admin" asp-action="Tickets" class="block w-full text-left px-4 py-3.5 text-slate-300 hover:bg-slate-800 hover:text-white rounded-xl text-sm font-medium transition-colors flex items-center group">
                <i class="fas fa-headset w-6 text-slate-500 group-hover:text-purple-400 transition-colors"></i> Mesa de Ayuda (Tickets)
            </a>
        </nav>
    </aside>

    <!-- ========================================== -->
    <!-- CONTENIDO PRINCIPAL                        -->
    <!-- ========================================== -->
    <main class="flex-1 p-8 lg:p-12 overflow-y-auto w-full">

        <!-- Cabecera y Botón de Retorno -->
        <div class="mb-10 border-b border-slate-200 pb-6 flex items-center gap-5">
            <a asp-action="Inventario" class="w-14 h-14 rounded-2xl bg-white border-2 border-slate-200 flex items-center justify-center text-slate-400 hover:text-blue-700 hover:border-blue-400 hover:bg-blue-50 transition-all shadow-sm flex-shrink-0 group">
                <i class="fas fa-arrow-left text-xl group-hover:-translate-x-1 transition-transform"></i>
            </a>

            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Editar: @Model.Nombre</h1>
                <p class="text-sm md:text-base text-slate-500 mt-1 font-medium">Actualiza precios, disponibilidad o detalles del artículo.</p>
            </div>
        </div>

        <div class="max-w-4xl bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-slate-200">

            <form asp-action="EditarProducto" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <!-- Nombre del Artículo -->
                    <div class="md:col-span-2">
                        <label asp-for="Nombre" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Nombre del Artículo *</label>
                        <div class="relative">
                            <i class="fas fa-box absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input asp-for="Nombre" required class="w-full pl-11 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800" />
                        </div>
                    </div>

                    <!-- Precio -->
                    <div>
                        <label asp-for="Precio" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Precio (Bs.) *</label>
                        <div class="relative">
                            <i class="fas fa-tag absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input asp-for="Precio" type="number" step="0.01" required class="w-full pl-11 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-black text-slate-800" />
                        </div>
                    </div>

                    <!-- Categoría -->
                    <div>
                        <label asp-for="Categoria" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Categoría</label>
                        <div class="relative">
                            <i class="fas fa-tags absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input asp-for="Categoria" class="w-full pl-11 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700" />
                        </div>
                    </div>

                    <!-- Checkbox Servicio -->
                    <div class="md:col-span-2 flex items-center p-5 bg-purple-50/50 border-2 border-purple-100 rounded-2xl hover:bg-purple-50 hover:border-purple-200 transition-colors cursor-pointer" onclick="document.getElementById('chkServicio').click();">
                        <div class="flex items-center h-5">
                            <input asp-for="EsServicio" type="checkbox" id="chkServicio" class="w-5 h-5 text-purple-600 bg-white border-slate-300 rounded focus:ring-purple-500 cursor-pointer" onclick="event.stopPropagation();" />
                        </div>
                        <div class="ml-3 text-sm flex-1">
                            <label asp-for="EsServicio" class="font-bold text-slate-800 cursor-pointer">Catalogar como Servicio IT</label>
                            <p class="text-xs text-slate-500 mt-0.5">Desactiva el control de stock y cambia el identificador visual en la tienda.</p>
                        </div>
                        <i class="fas fa-network-wired text-purple-300 text-3xl ml-4"></i>
                    </div>

                    <!-- Unidades en Stock -->
                    <div id="contenedorStock" class="md:col-span-2">
                        <label asp-for="Stock" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Unidades en Stock *</label>
                        <div class="relative">
                            <i class="fas fa-cubes absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input asp-for="Stock" id="inputStock" type="number" class="w-full pl-11 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-bold text-slate-800" />
                        </div>
                    </div>

                    <!-- URL Imagen -->
                    <div class="md:col-span-2">
                        <label asp-for="UrlImagen" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">URL de la Imagen</label>
                        <div class="relative">
                            <i class="fas fa-image absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input asp-for="UrlImagen" type="url" class="w-full pl-11 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700" placeholder="https://ejemplo.com/imagen.png" />
                        </div>
                    </div>

                    <!-- Descripción Corta -->
                    <div class="md:col-span-2">
                        <label asp-for="DescripcionCorta" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5 ml-1">Descripción Corta</label>
                        <div class="relative">
                            <i class="fas fa-align-left absolute left-4 top-4 text-slate-400"></i>
                            <textarea asp-for="DescripcionCorta" rows="3" class="w-full pl-11 pr-4 py-3 border-2 border-slate-100 rounded-xl text-sm bg-slate-50 outline-none focus:bg-white focus:border-blue-600 focus:ring-0 transition-colors font-medium text-slate-700 resize-y"></textarea>
                        </div>
                    </div>

                </div>

                <div class="mt-10 pt-6 border-t border-slate-100 flex justify-end gap-4">
                    <a asp-action="Inventario" class="px-6 py-3.5 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-slate-600 font-bold shadow-sm transition-all">Cancelar</a>
                    <button type="submit" class="px-8 py-3.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-black shadow-lg hover:shadow-emerald-600/30 transition-all flex items-center gap-2 group">
                        <i class="fas fa-save group-hover:scale-110 transition-transform"></i> Actualizar Artículo
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

@section Scripts {
    <script>
        const chkServicio = document.getElementById('chkServicio');
        const contenedorStock = document.getElementById('contenedorStock');
        const inputStock = document.getElementById('inputStock');

        function toggleStock() {
            if (chkServicio.checked) {
                // Ocultar suavemente
                contenedorStock.style.opacity = '0';
                setTimeout(() => {
                    contenedorStock.style.display = 'none';
                    // Opcional: setear a 0 si es servicio para no romper validaciones en bd
                    if(inputStock.value === '') inputStock.value = 0;
                }, 200);
            } else {
                // Mostrar suavemente
                contenedorStock.style.display = 'block';
                setTimeout(() => {
                    contenedorStock.style.opacity = '1';
                }, 10);
            }
        }

        chkServicio.addEventListener('change', toggleStock);

        // Estilo inicial de transición
        contenedorStock.style.transition = 'opacity 0.2s ease-in-out';
        toggleStock();
    </script>
}