@model BastionTech.Models.Producto
@{
    ViewData["Title"] = "Editar Artículo";
}

<div class="max-w-4xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="flex items-center mb-6">
        <a asp-action="Inventario" class="text-slate-400 hover:text-blue-800 transition-colors mr-4">
            <i class="fas fa-arrow-left text-xl"></i>
        </a>
        <div>
            <h1 class="text-3xl font-black text-slate-800">Editar: @Model.Nombre</h1>
            <p class="text-sm text-slate-500 mt-1">Actualiza precios, stock o detalles del artículo</p>
        </div>
    </div>

    <form asp-action="EditarProducto" method="post" class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">

        <input type="hidden" asp-for="Id" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="md:col-span-2">
                <label asp-for="Nombre" class="block text-sm font-bold text-slate-700 mb-2">Nombre del Artículo *</label>
                <input asp-for="Nombre" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
            </div>

            <div>
                <label asp-for="Precio" class="block text-sm font-bold text-slate-700 mb-2">Precio ($) *</label>
                <input asp-for="Precio" type="number" step="0.01" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
            </div>

            <div>
                <label asp-for="Categoria" class="block text-sm font-bold text-slate-700 mb-2">Categoría</label>
                <input asp-for="Categoria" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
            </div>

            <div class="md:col-span-2 flex items-center p-4 bg-slate-50 border border-slate-200 rounded-lg">
                <input asp-for="EsServicio" type="checkbox" id="chkServicio" class="w-5 h-5 text-blue-600 rounded border-slate-300 focus:ring-blue-500" />
                <label asp-for="EsServicio" class="ml-3 text-sm font-bold text-slate-700">Este artículo es un Servicio IT</label>
            </div>

            <div id="contenedorStock">
                <label asp-for="Stock" class="block text-sm font-bold text-slate-700 mb-2">Unidades en Stock *</label>
                <input asp-for="Stock" id="inputStock" type="number" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
            </div>

            <div class="md:col-span-2">
                <label asp-for="UrlImagen" class="block text-sm font-bold text-slate-700 mb-2">URL de la Imagen</label>
                <input asp-for="UrlImagen" type="url" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" />
            </div>

            <div class="md:col-span-2">
                <label asp-for="DescripcionCorta" class="block text-sm font-bold text-slate-700 mb-2">Descripción Corta</label>
                <textarea asp-for="DescripcionCorta" rows="2" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all"></textarea>
            </div>

        </div>

        <div class="mt-8 flex justify-end space-x-4">
            <a asp-action="Inventario" class="px-6 py-2 border border-slate-300 rounded-lg text-slate-600 font-bold hover:bg-slate-50 transition-colors">Cancelar</a>
            <button type="submit" class="px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg font-bold shadow-sm transition-colors">Actualizar Artículo</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const chkServicio = document.getElementById('chkServicio');
        const contenedorStock = document.getElementById('contenedorStock');

        function toggleStock() {
            if (chkServicio.checked) {
                contenedorStock.classList.add('hidden');
            } else {
                contenedorStock.classList.remove('hidden');
            }
        }

        chkServicio.addEventListener('change', toggleStock);
        toggleStock();
    </script>
}